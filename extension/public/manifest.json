{
  "manifest_version": 3,
  "name": "NavGPT",
  "version": "1.0.0",
  "description": "A side panel for ChatGPT that lists your conversation prompts so you can quickly jump, copy, or edit without scrolling.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://navgpt-license-proxy.navgpt.workers.dev/*"
  ],

  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },

  "action": {
    "default_title": "NavGPT"
  },

  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/styles.css"],
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"]
    }
  ]
}

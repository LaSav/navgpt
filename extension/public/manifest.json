{
  "manifest_version": 3,
  "version": "1.0.10",
  "name": "NavGPT - Prompt & Edit History",
  "short_name": "NavGPT",
  "description": "Sidebar for ChatGPT: jump to any prompt, browse history, copy, bookmark, edit, export and navigate versions - all without scrolling.",
  "author": "Savva Lambin",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": ["storage"],
  "host_permissions": ["https://chatgpt.com/*"],

  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },

  "action": {
    "default_title": "NavGPT"
  },

  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/styles.css"],
      "matches": ["https://chatgpt.com/*"]
    }
  ]
}

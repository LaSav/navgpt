{
  "manifest_version": 3,
  "name": "ChatGPT Prompt History Sidebar",
  "version": "0.1.0",
  "description": "View prompt history in a side panel and jump to any prompt in ChatGPT.",
  "host_permissions": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/styles.css"],
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"]
    }
  ]
}

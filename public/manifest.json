{
  "manifest_version": 3,
  "name": "NavGPT",
  "version": "0.1.0",
  "description": "Navigate your ChatGPT prompts with ease. A side panel that lists your conversation prompts so you can quickly jump, copy, or edit without scrolling.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/styles.css"],
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"]
    }
  ]
}
